# Copy to .env and adjust.
#
# Base URL of the backend API (the backend is a separate project/app).
# Leave empty to use the relative "/api" path, which Vite proxies to the
# backend during development (see vite.config.ts).
#
# Development (talk to the local backend directly):
#   VITE_API_URL=http://localhost:3000
# Production (your deployed backend):
#   VITE_API_URL=https://api.namanjewels.com
VITE_API_URL=http://localhost:3000
